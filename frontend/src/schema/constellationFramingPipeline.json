{
    "pipeline": "ConstellationFramingPipeline",
    "agent": "FramingConstellationBot",
    "version": "1.0.0",
    "inputs": {
        "keywords": {
            "type": "array",
            "description": "Array of keyword objects from Notion DB2",
            "items": {
                "term": "string",
                "orientation": "exploratory | critical | problem_solving | constructive",
                "artifact_role": "probe | critique_device | generative_construct | solution_system | epistemic_mediator",
                "pipeline_role?": "rq_trigger | method_bias | contribution_frame | tone_modifier",
                "weight?": "number (0-1, default 1.0)",
                "active?": "boolean (default true)",
                "notes?": "string"
            }
        },
        "research_context": {
            "type": "string",
            "description": "Structured and composed research-context text used by the framing generator"
        }
    },
    "steps": [
        {
            "id": "step_1",
            "skill": "ConstellationKeywordSync",
            "type": "deterministic",
            "input": {
                "keywords": "$.inputs.keywords"
            },
            "output": {
                "keyword_map_by_orientation": "$.state.keyword_map_by_orientation",
                "keyword_index": "$.state.keyword_index",
                "epistemic_profile": "$.state.epistemic_profile",
                "artifact_profile": "$.state.artifact_profile"
            }
        },
        {
            "id": "step_2",
            "skill": "ArtifactRoleInfluencer",
            "type": "deterministic",
            "input": {
                "artifact_profile": "$.state.artifact_profile",
                "epistemic_profile": "$.state.epistemic_profile",
                "keyword_map_by_orientation": "$.state.keyword_map_by_orientation",
                "keyword_index": "$.state.keyword_index"
            },
            "output": {
                "framing_bias": "$.state.framing_bias"
            }
        },
        {
            "id": "step_3",
            "skill": "ConstellationRuleEngine",
            "type": "deterministic",
            "input": {
                "epistemic_profile": "$.state.epistemic_profile",
                "keyword_map_by_orientation": "$.state.keyword_map_by_orientation",
                "keyword_index": "$.state.keyword_index",
                "framing_bias": "$.state.framing_bias"
            },
            "output": {
                "reasoning_control": "$.state.reasoning_control"
            }
        },
        {
            "id": "step_4",
            "skill": "FramingGeneratorMVP",
            "type": "llm",
            "input": {
                "research_context": "$.inputs.research_context",
                "rule_engine_output": "$.state.reasoning_control"
            },
            "output": {
                "research_question_en": "$.state.research_question_en",
                "background_en": "$.state.background_en",
                "purpose_en": "$.state.purpose_en",
                "method_en": "$.state.method_en",
                "result_en": "$.state.result_en",
                "contribution_en": "$.state.contribution_en"
            }
        },
        {
            "id": "step_5",
            "skill": "ConstellationAbstractGenerator",
            "type": "llm",
            "input": {
                "background": "$.state.background",
                "purpose": "$.state.purpose",
                "method": "$.state.method",
                "result": "$.state.result",
                "contribution": "$.state.contribution"
            },
            "output": {
                "abstract_en": "$.state.abstract_en",
                "abstract_zh": "$.state.abstract_zh"
            }
        },
        {
            "id": "step_6",
            "skill": "TitleGenerator",
            "type": "llm",
            "input": {
                "research_question": "$.state.research_question_en",
                "background": "$.state.background_en",
                "purpose": "$.state.purpose_en",
                "method": "$.state.method_en",
                "result": "$.state.result_en",
                "contribution": "$.state.contribution_en",
                "abstract_en": "$.state.abstract_en",
                "abstract_zh": "$.state.abstract_zh",
                "keyword_map_by_orientation": "$.state.keyword_map_by_orientation",
                "epistemic_profile": "$.state.epistemic_profile"
            },
            "output": {
                "title_en": "$.state.title_en"
            }
        }
    ],
    "outputs": {
        "title": { "en": "$.state.title_en", "zh": "$.state.title_zh" },
        "research_question": { "en": "$.state.research_question_en", "zh": "$.state.research_question_zh" },
        "background": { "en": "$.state.background_en", "zh": "$.state.background_zh" },
        "purpose": { "en": "$.state.purpose_en", "zh": "$.state.purpose_zh" },
        "method": { "en": "$.state.method_en", "zh": "$.state.method_zh" },
        "result": { "en": "$.state.result_en", "zh": "$.state.result_zh" },
        "contribution": { "en": "$.state.contribution_en", "zh": "$.state.contribution_zh" },
        "abstract": { "en": "$.state.abstract_en", "zh": "$.state.abstract_zh" }
    }
}
